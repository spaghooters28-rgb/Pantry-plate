# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# docker-compose wires this automatically; set manually for Railway/Render/Neon
DATABASE_URL=postgres://user:password@host:5432/database

# Secret used to sign session cookies — generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Google Gemini API key — get yours free at https://aistudio.google.com
GEMINI_API_KEY=AIza...

# ── Self-hosting ───────────────────────────────────────────────────────────────

# Set to "true" to unlock all features for all authenticated users (no subscriptions)
SELF_HOSTED=true

# Port the server listens on (default: 3000)
PORT=3000

# ── Optional ──────────────────────────────────────────────────────────────────

# Comma-separated list of extra allowed CORS origins (only needed if your
# frontend and API are hosted on different domains)
ALLOWED_ORIGINS=

# Stripe keys — leave blank to disable payment features entirely
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend API key — leave blank to disable password-reset emails
RESEND_API_KEY=

# ── Replit-specific (not needed for self-hosting) ─────────────────────────────
# REPLIT_DOMAINS=
# REPLIT_DEV_DOMAIN=
